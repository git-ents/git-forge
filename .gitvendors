[vendor "git-vendor"]
	url = https://github.com/git-ents/git-vendor.git
	branch = main
	base = ad4a703e4ee583aeca7d915a48a4dec8d8dec4a4
	pattern = .github/
	pattern = .config/
[vendor "git-kiln"]
	url = https://github.com/git-ents/git-kiln
	base = 1350143f7e65babc9756bac1fe9bb732f3af3da0
	pattern = crates/**
	pattern = docs/**
